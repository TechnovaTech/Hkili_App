{
  "expo": {
    "name": "Unaï",
    "slug": "ai-storytelling-app",
    "version": "1.0.0",
    "icon": "./assets/images/icon-unai.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/icon-unai-foreground.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B7A3B"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.company.aistorytelling",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "We use the microphone so you can record your voice and use it as the story narrator."
      }
    },
    "android": {
      "package": "com.company.aistorytelling",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-unai-foreground.png",
        "backgroundColor": "#12A24C"
      },
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "scheme": "ai-storytelling",
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "We use the microphone so you can record your voice and use it as the story narrator."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "We access your photos so you can add your own pictures to a story."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "181d0d1a-5828-4ec2-a2bc-26bb4c7263f2"
      }
    }
  }
}
